# LeadPilot environment reference (local dev only)
# For deployment uploads, use the files in /deploy:
#   deploy/vercel.env.example  → upload to Vercel
#   deploy/render.env.example  → upload to Render

# Frontend — copy to frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend — copy to backend/.env
PORT=3001
NODE_ENV=development
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key
SCRAPER_CONCURRENCY=3
FRONTEND_URL=http://localhost:3000
