# Copy to backend/.env.staging (gitignored) to run staging integration tests locally:
#   cd backend && node scripts/verify-mailbox-flow.mjs
#
# Values from LeadPilot Staging → Project Settings → API

USE_REAL_SUPABASE=1
SUPABASE_URL=https://YOUR_LEADPILOT_STAGING_REF.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
MAILBOX_ENCRYPTION_KEY=your_64_char_hex_key_here

# Optional: live Gmail SMTP connect test
# GMAIL_TEST_EMAIL=you@gmail.com
# GMAIL_TEST_APP_PASSWORD=your16charapppass
