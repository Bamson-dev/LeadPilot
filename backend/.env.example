# Generate JWT_SECRET with:
# openssl rand -hex 64
#
# Generate ADMIN_PASSWORD with:
# openssl rand -base64 32
#
# RESEND TRANSACTIONAL EMAIL (fallback when ZeptoMail fails)
# Add RESEND_API_KEY and EMAIL_FROM in Coolify backend runtime env.
# Verify leadthur.com domain in Resend dashboard (SPF/DKIM) before going live.
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=access@leadthur.com
# ZEPTOMAIL TRANSACTIONAL EMAIL (primary)
ZEPTOMAIL_API_KEY=your_zeptomail_api_key
ZEPTOMAIL_API_URL=https://api.zeptomail.com/v1.1/email
ZEPTOMAIL_FROM_EMAIL=noreply@leadthur.com
# Gmail outreach mailbox encryption (32-byte key as 64-char hex)
# Generate with: openssl rand -hex 32
MAILBOX_ENCRYPTION_KEY=your_64_char_hex_key_here
# Outreach send queue: set to 1 on staging until live SMTP is verified
MOCK_OUTREACH_SEND=1
# Optional override for open-tracking pixel URLs (defaults from FRONTEND_URL)
# OUTREACH_TRACKING_BASE_URL=https://staging-backend.leadthur.com
# Paystack (test keys on staging — sk_test_... / pk_test_...)
# PAYSTACK_SECRET_KEY=sk_test_...
ADMIN_EMAIL=your_admin_email@gmail.com
ADMIN_PASSWORD=your_admin_password
JWT_SECRET=generate-with-openssl-rand-hex-64
LIFETIME_ACCESS_PRICE=2500000
# Required for AI WhatsApp messages and search area suggestions.
# Create at https://platform.deepseek.com — set in Coolify BACKEND runtime env (not Vercel).
# No quotes around the value. After saving, redeploy the backend container.
DEEPSEEK_API_KEY=your_deepseek_api_key
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
# GET /search/:id, /search/results/:id, and stream polls during long searches
RATE_LIMIT_SEARCH_POLL_MAX=180
# Comma-separated IPs that bypass the per-IP rate limit (testing only). Does not affect trial search limits.
# RATE_LIMIT_IP_ALLOWLIST=162.120.188.117

# Search volume budgets (optional overrides)
# PHASE1_DEADLINE_MS=180000
# BACKGROUND_MAPS_BUDGET_MS=270000
# SEARCH_JOB_TIMEOUT_MS=900000
# BULLMQ_LOCK_DURATION_MS=1200000
# NEARBY_CITY_SUGGESTION_THRESHOLD=400
# AREA_SUGGESTION_THRESHOLD=350
