# Generate JWT_SECRET with:
# openssl rand -hex 64
#
# Generate ADMIN_PASSWORD with:
# openssl rand -base64 32
#
# BREVO DOMAIN AUTHENTICATION
# Add these in Cloudflare DNS for leadthur.com:
# 1. Go to Brevo → Senders & IP → Domains → Add Domain → leadthur.com
# 2. Brevo will give you SPF, DKIM, and DMARC records
# 3. Add each one as a TXT record in Cloudflare DNS
# This prevents activation emails going to spam

PORT=3000
NODE_ENV=production
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key
SCRAPER_CONCURRENCY=3
FRONTEND_URL=https://www.leadthur.com
PAYSTACK_SECRET_KEY=your_paystack_secret_key
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_SECRET_HASH=your_webhook_secret_hash
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=access@leadthur.com
ADMIN_EMAIL=your_admin_email@gmail.com
ADMIN_PASSWORD=your_admin_password
JWT_SECRET=generate-with-openssl-rand-hex-64
LIFETIME_ACCESS_PRICE=1500000
DEEPSEEK_API_KEY=your_deepseek_api_key
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
