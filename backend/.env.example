# Generate JWT_SECRET with:
# openssl rand -hex 64
#
# Generate ADMIN_PASSWORD with:
# openssl rand -base64 32
#
# BREVO DOMAIN AUTHENTICATION
# Add these in Cloudflare DNS for leadpilot.live:
# 1. Go to Brevo → Senders & IP → Domains → Add Domain → leadpilot.live
# 2. Brevo will give you SPF, DKIM, and DMARC records
# 3. Add each one as a TXT record in Cloudflare DNS
# This prevents activation emails going to spam

PORT=3000
NODE_ENV=production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SCRAPER_CONCURRENCY=5
FRONTEND_URL=https://www.leadpilot.live
# Optional: comma-separated Vercel preview URLs
# CORS_ORIGINS=https://leadpilot.vercel.app

ADMIN_EMAIL=your-admin-email@gmail.com
ADMIN_PASSWORD=your-strong-password-here
JWT_SECRET=generate-with-openssl-rand-hex-64
LIFETIME_ACCESS_PRICE=1500000

PAYSTACK_SECRET_KEY=sk_live_your_key_here
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_your_key_here
FLUTTERWAVE_SECRET_HASH=your_webhook_secret_hash
BREVO_API_KEY=xkeysib-your-key-here
BREVO_SENDER_EMAIL=access@leadpilot.live

DEEPSEEK_API_KEY=your-deepseek-api-key-here

RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
